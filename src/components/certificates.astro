---
const totalCertificates = 16;
const certificates = Array.from({ length: totalCertificates }, (_, i) => ({
  id: i + 1,
  src: `/certificates/certificado_${i + 1}.png`,
  alt: `Certificate ${i + 1}`
}));
---

<section id="certificates-section" class="certificates-container">
  <h2 class="certificates-title">Certifications</h2>
  <p class="certificates-subtitle">My achievements and professional certifications</p>
  
  <div class="certificates-grid">
    {certificates.map(cert => (
      <div class="certificate-card">
        <div class="certificate-image-wrapper">
          <img 
            src={cert.src} 
            alt={cert.alt}
            class="certificate-image"
            loading="lazy"
          />
          <div class="certificate-overlay">
            <button class="view-btn" onclick={`window.open('${cert.src}', '_blank')`}>
              View Certificate
            </button>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="cta-section">
    <p class="cta-text">
      If you want to see all my certifications and download my CV, you can click the buttons below.
    </p>
    <div class="cta-buttons">
      <a href="https://drive.google.com/drive/folders/17wNozNMjEvSuC0H97HyaA2DuIXbwQHLE?usp=sharing" 
         target="_blank" 
         rel="noopener noreferrer" 
         class="cta-button primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/>
        </svg>
        View All Certificates
      </a>
      <a href="/CV_JACOBO_MONROY_C.pdf" 
         download 
         class="cta-button secondary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download My CV
      </a>
    </div>
  </div>
</section>

<style>
  .certificates-container {
    padding: 4rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 10;
  }

  .certificates-title {
    font-size: 3.2rem;
    font-weight: 900;
    text-align: center;
    margin-bottom: 1rem;
    color: #00ff4c;
    font-family: 'Courier New', monospace;
    position: relative;
    text-transform: uppercase;
    letter-spacing: 5px;
  }

  .certificates-title::before {
    content: '< ';
    color: #39ff14;
    margin-right: 10px;
  }

  .certificates-title::after {
    content: ' />';
    color: #39ff14;
    margin-left: 10px;
  }

  .certificates-subtitle {
    text-align: center;
    color: rgba(57, 255, 20, 0.7);
    font-size: 1rem;
    margin-bottom: 3rem;
    font-family: 'Courier New', monospace;
    letter-spacing: 2px;
  }

  .certificates-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    padding: 1rem 0;
  }

  .certificate-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(0, 255, 76, 0.2);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .certificate-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px rgba(0, 255, 76, 0.3);
    border-color: #39ff14;
  }

  .certificate-image-wrapper {
    position: relative;
    width: 100%;
    padding-top: 70.7%; /* Ratio típico de certificados */
    overflow: hidden;
  }

  .certificate-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .certificate-card:hover .certificate-image {
    transform: scale(1.05);
  }

  .certificate-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .certificate-card:hover .certificate-overlay {
    opacity: 1;
  }

  .view-btn {
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #00ff4c, #00d9ff);
    color: #060707;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .view-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 20px rgba(0, 255, 76, 0.5);
  }

  @media (max-width: 768px) {
    .certificates-container {
      padding: 3rem 1rem;
    }

    .certificates-title {
      font-size: 2rem;
    }

    .certificates-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .certificates-grid {
      grid-template-columns: 1fr;
    }
  }

  .cta-section {
    margin-top: 4rem;
    text-align: center;
    padding: 2rem;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 16px;
    border: 1px solid rgba(57, 255, 20, 0.2);
  }

  .cta-text {
    font-size: 1.1rem;
    color: rgba(233, 255, 243, 0.85);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .cta-link {
    color: #39ff14;
    text-decoration: underline;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .cta-link:hover {
    color: #00d9ff;
    text-shadow: 0 0 10px rgba(57, 255, 20, 0.5);
  }

  .cta-buttons {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 2px solid;
    cursor: pointer;
  }

  .cta-button.primary {
    background: rgba(57, 255, 20, 0.1);
    color: #39ff14;
    border-color: #39ff14;
  }

  .cta-button.primary:hover {
    background: #39ff14;
    color: #060707;
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(57, 255, 20, 0.4);
  }

  .cta-button.secondary {
    background: rgba(0, 217, 255, 0.1);
    color: #00d9ff;
    border-color: #00d9ff;
  }

  .cta-button.secondary:hover {
    background: #00d9ff;
    color: #060707;
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0, 217, 255, 0.4);
  }

  .cta-button svg {
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .cta-text {
      font-size: 1rem;
    }

    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }

    .cta-button {
      width: 100%;
      max-width: 300px;
    }
  }
</style>