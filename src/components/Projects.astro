---
import infoproyects from '../assets/infoproyects.json';

const projects = infoproyects;
---

<section id="projects-section">
    <div class="projectsContainer">
        <h2 class="section-title">My Projects</h2>
        <div class="projects-grid">
            {projects.map((project) => (
                <div class="project-card">
                    <div class="project-header">
                        <h3 class="project-title">{project.title}</h3>
                    </div>
                    <p class="project-description">{project.description}</p>
                    <div class="technologies">
                        {project.tecnologies.map((tech) => (
                            <span class="tech-tag">{tech}</span>
                        ))}
                    </div>
                    <div class="project-links">
                        {project.repository && (
                            <a href={project.repository} target="_blank" rel="noopener noreferrer" class="project-link" title="GitHub Repository">
                                <img src="https://img.icons8.com/color-glass/96/github--v1.png" alt="GitHub" width="32" height="32" />
                                <span>Repository</span>
                            </a>
                        )}
                        {project.website && (
                            <a href={project.website} target="_blank" rel="noopener noreferrer" class="project-link website" title="Visit Website">
                                <img src="https://img.icons8.com/color/96/domain--v1.png" alt="Website" width="32" height="32" />
                                <span>Website</span>
                            </a>
                        )}
                    </div>
                </div>
            ))}
        </div>
        
        <div class="github-cta">
            <div class="cta-content">
                <div class="cta-icon">
                    <img src="https://img.icons8.com/color-glass/96/github--v1.png" alt="GitHub" width="64" height="64" />
                </div>
                <h3 class="cta-text">
                    You can see my <span class="highlight">40+ projects</span> available on 
                    <a href="https://github.com/KillahBlitz" target="_blank" rel="noopener noreferrer" class="github-link">
                        GITHUB
                    </a>
                </h3>
            </div>
        </div>
    </div>
</section>

<style>
    #projects-section {
        width: 100%;
        padding: 4rem 0;
        background: transparent;
        min-height: 100vh;
        position: relative;
    }

    .projectsContainer {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .section-title {
        text-align: center;
        margin-bottom: 3rem;
        font-size: 2.5rem;
        color: var(--fg);
        font-weight: 700;
        text-shadow: 0 0 20px rgba(57, 255, 20, 0.3);
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 2rem;
        padding: 1rem 0;
    }

    .project-card {
        background: rgba(0, 0, 0, 0.6);
        border: 2px solid rgba(57, 255, 20, 0.3);
        border-radius: 16px;
        padding: 1.5rem;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        backdrop-filter: blur(10px);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    }

    .project-card:hover {
        transform: translateY(-5px);
        border-color: var(--neon);
        box-shadow: 
            0 8px 30px rgba(0, 0, 0, 0.4),
            0 0 30px rgba(57, 255, 20, 0.2);
    }

    .project-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.5rem;
    }

    .project-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--fg);
        margin: 0;
        line-height: 1.3;
    }

    .project-description {
        color: var(--muted);
        font-size: 0.95rem;
        line-height: 1.6;
        flex-grow: 1;
        margin: 0;
    }

    .technologies {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .tech-tag {
        background: rgba(57, 255, 20, 0.15);
        color: rgba(57, 255, 20, 0.95);
        padding: 0.35rem 0.75rem;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 500;
        border: 1px solid rgba(57, 255, 20, 0.3);
        transition: all 0.2s ease;
    }

    .tech-tag:hover {
        background: rgba(57, 255, 20, 0.25);
        border-color: var(--neon);
    }

    .project-links {
        display: flex;
        gap: 1rem;
        margin-top: 0.5rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(57, 255, 20, 0.2);
    }

    .project-link {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1rem;
        background: rgba(57, 255, 20, 0.1);
        border: 1px solid rgba(57, 255, 20, 0.3);
        border-radius: 8px;
        color: var(--fg);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s ease;
        flex: 1;
        justify-content: center;
    }

    .project-link:hover {
        background: rgba(57, 255, 20, 0.2);
        border-color: var(--neon);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(57, 255, 20, 0.3);
    }

    .project-link img {
        filter: drop-shadow(0 0 4px rgba(57, 255, 20, 0.3));
    }

    .project-link.website {
        background: rgba(0, 150, 255, 0.1);
        border-color: rgba(0, 150, 255, 0.3);
    }

    .project-link.website:hover {
        background: rgba(0, 150, 255, 0.2);
        border-color: rgba(0, 150, 255, 0.8);
        box-shadow: 0 4px 12px rgba(0, 150, 255, 0.3);
    }

    .github-cta {
        margin-top: 4rem;
        display: flex;
        justify-content: center;
        padding: 2rem;
    }

    .cta-content {
        position: relative;
        background: rgba(0, 0, 0, 0.7);
        border: 2px solid rgba(57, 255, 20, 0.4);
        border-radius: 20px;
        padding: 2.5rem 3rem;
        display: flex;
        align-items: center;
        gap: 2rem;
        backdrop-filter: blur(15px);
        box-shadow: 
            0 8px 32px rgba(0, 0, 0, 0.4),
            0 0 40px rgba(57, 255, 20, 0.15);
        transition: all 0.4s ease;
        animation: pulseGlow 3s ease-in-out infinite;
    }

    @keyframes pulseGlow {
        0%, 100% {
            box-shadow: 
                0 8px 32px rgba(0, 0, 0, 0.4),
                0 0 40px rgba(57, 255, 20, 0.15);
            border-color: rgba(57, 255, 20, 0.4);
        }
        50% {
            box-shadow: 
                0 8px 32px rgba(0, 0, 0, 0.4),
                0 0 60px rgba(57, 255, 20, 0.3);
            border-color: rgba(57, 255, 20, 0.6);
        }
    }

    .cta-content:hover {
        transform: translateY(-5px) scale(1.02);
        border-color: var(--neon);
        box-shadow: 
            0 12px 40px rgba(0, 0, 0, 0.5),
            0 0 80px rgba(57, 255, 20, 0.4);
    }

    .cta-icon {
        animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% {
            transform: translateY(0px) rotate(0deg);
        }
        25% {
            transform: translateY(-10px) rotate(-5deg);
        }
        50% {
            transform: translateY(-5px) rotate(0deg);
        }
        75% {
            transform: translateY(-10px) rotate(5deg);
        }
    }

    .cta-icon img {
        filter: drop-shadow(0 0 10px rgba(57, 255, 20, 0.4));
    }

    .cta-text {
        font-size: 1.5rem;
        color: var(--fg);
        margin: 0;
        font-weight: 500;
        line-height: 1.4;
    }

    .highlight {
        color: var(--neon);
        font-weight: 700;
        text-shadow: 0 0 15px rgba(57, 255, 20, 0.5);
        animation: shimmer 2s ease-in-out infinite;
    }

    @keyframes shimmer {
        0%, 100% {
            opacity: 1;
            text-shadow: 0 0 15px rgba(57, 255, 20, 0.5);
        }
        50% {
            opacity: 0.8;
            text-shadow: 0 0 25px rgba(57, 255, 20, 0.8);
        }
    }

    .github-link {
        color: var(--neon);
        text-decoration: none;
        font-weight: 700;
        position: relative;
        display: inline-block;
        text-shadow: 0 0 15px rgba(57, 255, 20, 0.5);
        transition: all 0.3s ease;
    }

    .github-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--neon), transparent);
        transform: scaleX(0);
        transition: transform 0.3s ease;
    }

    .github-link:hover {
        color: #ffffff;
        text-shadow: 0 0 20px rgba(57, 255, 20, 0.8);
        transform: translateY(-2px);
    }

    .github-link:hover::after {
        transform: scaleX(1);
        animation: slideGlow 1s ease-in-out infinite;
    }

    @keyframes slideGlow {
        0%, 100% {
            opacity: 1;
        }
        50% {
            opacity: 0.6;
        }
    }

    @media (max-width: 1200px) {
        .projects-grid {
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        }
    }

    @media (max-width: 768px) {
        .projects-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .projectsContainer {
            padding: 0 1rem;
        }

        .section-title {
            font-size: 2rem;
        }

        .cta-content {
            flex-direction: column;
            padding: 2rem 1.5rem;
            text-align: center;
            gap: 1.5rem;
        }

        .cta-text {
            font-size: 1.2rem;
        }

        .cta-icon img {
            width: 48px;
            height: 48px;
        }
    }
</style>
