---
---

<div class="animated-bg">
  <canvas id="bgCanvas"></canvas>
  <div class="overlay-layer"></div>
</div>

<script>
  const canvas = document.getElementById('bgCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let width = window.innerWidth;
  let height = window.innerHeight;

  canvas.width = width;
  canvas.height = height;

  window.addEventListener('resize', () => {
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;
  });

  class Particle {
    x: number;
    y: number;
    size: number;
    speedX: number;
    speedY: number;
    life: number;
    maxLife: number;
    opacity: number;

    constructor() {
      this.x = Math.random() * width;
      this.y = Math.random() * height;
      this.size = Math.random() * 2 + 0.5;
      this.speedX = (Math.random() - 0.5) * 0.5;
      this.speedY = (Math.random() - 0.5) * 0.5;
      this.maxLife = Math.random() * 200 + 100;
      this.life = 0;
      this.opacity = 0;
    }

    update() {
      this.x += this.speedX;
      this.y += this.speedY;
      this.life++;

      // Fade in and out
      if (this.life < this.maxLife * 0.3) {
        this.opacity = this.life / (this.maxLife * 0.3);
      } else if (this.life > this.maxLife * 0.7) {
        this.opacity = (this.maxLife - this.life) / (this.maxLife * 0.3);
      } else {
        this.opacity = 1;
      }

      // Reset particle
      if (this.life >= this.maxLife) {
        this.x = Math.random() * width;
        this.y = Math.random() * height;
        this.life = 0;
        this.maxLife = Math.random() * 200 + 100;
      }

      // Wrap around screen
      if (this.x < 0) this.x = width;
      if (this.x > width) this.x = 0;
      if (this.y < 0) this.y = height;
      if (this.y > height) this.y = 0;
    }

    draw() {
      ctx.fillStyle = `rgba(0, 255, 76, ${this.opacity * 0.6})`;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fill();

      // Glow effect
      ctx.shadowBlur = 10;
      ctx.shadowColor = 'rgba(0, 255, 76, 0.5)';
    }
  }

  class Line {
    x1: number;
    y1: number;
    x2: number;
    y2: number;
    life: number;
    maxLife: number;
    opacity: number;
    isHorizontal: boolean;

    constructor() {
      this.isHorizontal = Math.random() > 0.5;
      this.maxLife = Math.random() * 150 + 100;
      this.life = 0;
      this.opacity = 0;

      if (this.isHorizontal) {
        this.y1 = this.y2 = Math.random() * height;
        this.x1 = Math.random() > 0.5 ? -100 : width + 100;
        this.x2 = this.x1;
      } else {
        this.x1 = this.x2 = Math.random() * width;
        this.y1 = Math.random() > 0.5 ? -100 : height + 100;
        this.y2 = this.y1;
      }
    }

    update() {
      this.life++;

      // Fade in and out
      if (this.life < this.maxLife * 0.2) {
        this.opacity = this.life / (this.maxLife * 0.2);
      } else if (this.life > this.maxLife * 0.8) {
        this.opacity = (this.maxLife - this.life) / (this.maxLife * 0.2);
      } else {
        this.opacity = 1;
      }

      // Extend line
      const progress = this.life / this.maxLife;
      if (this.isHorizontal) {
        const targetX = this.x1 < width / 2 ? width + 100 : -100;
        this.x2 = this.x1 + (targetX - this.x1) * progress;
      } else {
        const targetY = this.y1 < height / 2 ? height + 100 : -100;
        this.y2 = this.y1 + (targetY - this.y1) * progress;
      }

      // Reset line
      if (this.life >= this.maxLife) {
        this.isHorizontal = Math.random() > 0.5;
        this.maxLife = Math.random() * 150 + 100;
        this.life = 0;

        if (this.isHorizontal) {
          this.y1 = this.y2 = Math.random() * height;
          this.x1 = this.x2 = Math.random() > 0.5 ? -100 : width + 100;
        } else {
          this.x1 = this.x2 = Math.random() * width;
          this.y1 = this.y2 = Math.random() > 0.5 ? -100 : height + 100;
        }
      }
    }

    draw() {
      ctx.strokeStyle = `rgba(0, 255, 76, ${this.opacity * 0.3})`;
      ctx.lineWidth = 1.5;
      ctx.shadowBlur = 8;
      ctx.shadowColor = 'rgba(0, 255, 76, 0.4)';
      ctx.beginPath();
      ctx.moveTo(this.x1, this.y1);
      ctx.lineTo(this.x2, this.y2);
      ctx.stroke();
    }
  }

  const particles: Particle[] = [];
  const lines: Line[] = [];

  // Create particles
  for (let i = 0; i < 80; i++) {
    particles.push(new Particle());
  }

  // Create lines
  for (let i = 0; i < 8; i++) {
    lines.push(new Line());
  }

  function animate() {
    ctx.fillStyle = 'rgba(6, 7, 7, 0.1)';
    ctx.fillRect(0, 0, width, height);
    ctx.shadowBlur = 0;

    // Draw and update lines
    lines.forEach(line => {
      line.update();
      line.draw();
    });

    // Draw and update particles
    particles.forEach(particle => {
      particle.update();
      particle.draw();
    });

    // Connect nearby particles
    ctx.shadowBlur = 0;
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const distance = Math.sqrt(dx * dx + dy * dy);

        if (distance < 120) {
          const opacity = (1 - distance / 120) * 0.2 * Math.min(particles[i].opacity, particles[j].opacity);
          ctx.strokeStyle = `rgba(0, 255, 76, ${opacity})`;
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
        }
      }
    }

    requestAnimationFrame(animate);
  }

  animate();
</script>

<style>
  .animated-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    background: #060707;
    overflow: hidden;
  }

  #bgCanvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .overlay-layer {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    pointer-events: none;
    z-index: 1;
  }

  .animated-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.3;
    z-index: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(0, 255, 76, 0.05) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(0, 255, 76, 0.05) 0%, transparent 50%),
      radial-gradient(circle at 50% 50%, rgba(0, 255, 76, 0.03) 0%, transparent 70%);
  }
</style>
