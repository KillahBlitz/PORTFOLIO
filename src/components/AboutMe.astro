---
import fondo from '../assets/fondo.png';
import profile from '../assets/profile.jpeg';
---

<section id="container">
  <img src={fondo.src} alt="Background" class="background-img" />
  <div class="overlay"></div>
  <div class="founder">
    <div class="box-container">
        <div class="separator">
            <div class="aura">
                <img src={profile.src} class="profile" />
            </div>
        </div>
        <div class="presentation-content">
            <div class="text-box">
                <h2>About Me...</h2>
                <h1>Jacobo Monroy</h1>
                <h2>Computer Engineering Student and Aspiring Full Stack Developer.</h2>
                <p>
                    Computer Engineering student focused on software development. I aspire to become a full-stack developer and, later, a software architect.
                </p>
                <p>
                    I have experience in backend development and am currently expanding my frontend skills. I adapt easily to new technologies and am open to 
                    taking on different technical roles depending on the project's needs.
                </p>
            </div>
            <div class="contact-content">
                <a href="https://www.youtube.com/@beetlecode3" target="_blank" class="icon-link">
                    <img src="/icon/youtube.png" alt="YouTube" class="icon" />
                </a>
                <a href="https://www.linkedin.com/in/monroy-jacobo" target="_blank" class="icon-link">
                    <img src="/icon/linkedin.png" alt="LinkedIn" class="icon" />
                </a>
                <a href="https://github.com/KillahBlitz" target="_blank" class="icon-link">
                    <img src="/icon/github.svg" alt="GitHub" class="icon" />
                </a>
                <a href="/CV_JACOBO_MONROY_C.pdf" download class="icon-link">
                    <img src="/icon/cv.svg" alt="Portfolio" class="icon" />
                </a>
            </div>
        </div>
    </div>
    <div class="go-down-pages">
        
    </div>
  </div>
</section>

<style>
  #container {
    min-height: 100vh;
    width: 100%;
    position: relative;
    overflow: hidden;
    padding-top: 92px;
  }

  .background-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    padding-top: 30px;
    z-index: 0;
  }

  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    z-index: 1;
  }

  .founder {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 120px);
  }

  .box-container {
    display: flex;
    width: 1020px;
    height: 620px;
    background-color: rgba(0, 0, 0, 0.55);
    border-radius: 100px;
    border : 2px var(--neon);
    box-shadow: 0 0 30px var(--neon);
  }

  .separator {
    flex: 1;
    padding-top: 120px;
    padding-left: 70px;
  }

  .aura {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 250px;
    height: 250px;
    border-radius: 50%;
    position: relative;
    background: transparent;
  }

  .aura::before {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    border: 3px solid var(--neon);
    box-shadow: 
      0 0 20px var(--neon),
      0 0 40px var(--neon),
      inset 0 0 20px var(--neon);
    animation: neonPulse 2s ease-in-out infinite;
  }

  .aura::after {
    content: '';
    position: absolute;
    inset: -20px;
    border-radius: 50%;
    border: 2px solid var(--neon);
    opacity: 0.5;
    box-shadow: 
      0 0 30px var(--neon),
      0 0 60px var(--neon);
    animation: neonPulse 2s ease-in-out infinite reverse;
  }

  @keyframes neonPulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.7;
      transform: scale(1.05);
    }
  }

  .profile {
    width: 250px;
    height: 250px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center;
    border: 2px solid var(--neon);
    box-shadow: 0 0 20px var(--neon);
  }

  .presentation-content {
    flex: 2;
    padding: 60px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: justify;
    align-items: center;
    color: var(--fg);
  }

  .presentation-content h1 {
    font-size: 36px;
    margin: 10px 0;
    color: var(--neon);
    font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-shadow: 0 0 15px var(--neon);
    white-space: nowrap;
    overflow: hidden;
    border-right: 3px solid var(--neon);
    display: inline-block;
    max-width: fit-content;
    animation: typing 5s steps(30, end) infinite, blink 0.75s step-end infinite;
  }

  @keyframes typing {
    0% {
      width: 0;
    }
    40% {
      width: 100%;
    }
    60% {
      width: 100%;
    }
    100% {
      width: 0;
    }
  }

  @keyframes blink {
    0%, 50% {
      border-color: var(--neon);
    }
    51%, 100% {
      border-color: transparent;
    }
  }

  .presentation-content p {
    font-size: 16px;
    line-height: 1.8;
    color: rgba(233, 255, 243, 0.9);
    margin: 15px 0;
    padding: 15px 20px;
    border-left: 3px solid var(--neon);
    background: rgba(0, 255, 76, 0.03);
    border-radius: 0 8px 8px 0;
    box-shadow: 0 0 10px rgba(0, 255, 76, 0.1);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .presentation-content p::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 3px;
    background: linear-gradient(to bottom, transparent, var(--neon), transparent);
    animation: borderSlide 3s ease-in-out infinite;
  }

  @keyframes borderSlide {
    0%, 100% {
      transform: translateY(-100%);
    }
    50% {
      transform: translateY(100%);
    }
  }

  .presentation-content p:hover {
    background: rgba(0, 255, 76, 0.06);
    box-shadow: 0 0 20px rgba(0, 255, 76, 0.2);
    transform: translateX(5px);
  }

  .presentation-content h2 {
    color: #ffffff;
    font-size: 22px;
    font-weight: 600;
  }

  .contact-content {
    display: flex;
    gap: 20px;
    justify-content: center;
    align-items: center;
    margin-top: 2rem;
  }

  .icon-link {
    display: inline-block;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .icon {
    width: 50px;
    height: 50px;
    object-fit: contain;
  }

  .icon-link:hover {
    transform: translateY(-5px);
    filter: drop-shadow(0 0 15px var(--neon));
  }

</style>
