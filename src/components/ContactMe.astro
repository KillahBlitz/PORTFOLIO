---
// You can edit your contact information here
const contactInfo = {
  email: "jmonroyc2100@gmail.com",
  phone: "+52 55 8795 7504",
  location: "Mexico City, Mexico"
};
---

<section id="contact-section" class="contact-root">
  <div class="banner-contact">
    <h1 id="contact-title">Are you interested in my profile?</h1>
    <h2>Contact Me and together we can build many things.</h2>
  </div>

  <div class="contact-container">
    <div class="contact-content">
      <aside class="contact-info">
        <div class="info-box">
          <div class="info-icon">📧</div>
          <div>
            <h4>Email</h4>
            <p class="muted">{contactInfo.email}</p>
          </div>
        </div>

        <div class="info-box">
          <div class="info-icon">📞</div>
          <div>
            <h4>Phone</h4>
            <p class="muted phone-number">{contactInfo.phone}</p>
          </div>
        </div>

        <div class="info-box">
          <div class="info-icon">📍</div>
          <div>
            <h4>Location</h4>
            <p class="muted">{contactInfo.location}</p>
          </div>
        </div>
      </aside>

      <form class="contact-form" id="contactForm">
        <h3>Tell Me About Your Idea</h3>

        <div class="form-grid">
          <div>
            <input
              type="text"
              name="name"
              required
              placeholder="Name *"
              maxlength="40"
              autocomplete="name"
            />
            <p class="field-error" id="name-error"></p>
          </div>

          <div>
            <input
              type="email"
              name="email"
              required
              placeholder="Email *"
              maxlength="50"
              autocomplete="email"
            />
            <p class="field-error" id="email-error"></p>
          </div>

          <div>
            <input
              type="tel"
              name="phone"
              placeholder="Phone"
              maxlength="15"
              autocomplete="tel"
            />
            <p class="field-error" id="phone-error"></p>
          </div>

          <div>
            <input
              type="text"
              name="company"
              placeholder="Company"
              maxlength="60"
              autocomplete="organization"
            />
          </div>
        </div>

        <textarea
          name="message"
          rows="6"
          required
          placeholder="Describe your idea or project. What problem do you want to solve? What are your goals?"
        ></textarea>
        <p class="field-error" id="message-error"></p>

        <div class="form-actions">
          <button type="submit" class="send-btn">Send Message</button>
        </div>

        <p class="form-note" id="form-status"></p>
      </form>
    </div>
  </div>

  <div id="contactModal" class="modal-overlay" style="display: none;">
    <div class="modal-content">
      <div class="modal-icon success">
        <span id="modalIcon">✅</span>
      </div>
      <h4 id="modalTitle">Success!</h4>
      <p id="modalMessage">Your message has been sent successfully.</p>
      <button id="closeModal" class="modal-btn">Close</button>
    </div>
  </div>
</section>

<script>
  import emailjs from '@emailjs/browser';

  const EMAILJS_SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
  const EMAILJS_TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;
  const EMAILJS_PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;

  const form = document.getElementById('contactForm') as HTMLFormElement;
  const modal = document.getElementById('contactModal') as HTMLElement;
  const modalIcon = document.getElementById('modalIcon') as HTMLElement;
  const modalTitle = document.getElementById('modalTitle') as HTMLElement;
  const modalMessage = document.getElementById('modalMessage') as HTMLElement;
  const closeModalBtn = document.getElementById('closeModal') as HTMLButtonElement;
  const sendBtn = form.querySelector('.send-btn') as HTMLButtonElement;

  function sanitizeName(name: string): string {
    return name.replace(/[^A-Za-zÀ-ÖØ-öø-ÿ ]+/g, '').slice(0, 40);
  }

  function sanitizePhone(phone: string): string {
    return phone.replace(/\D/g, '').slice(0, 15);
  }

  function validateName(name: string): string {
    const v = name.trim();
    if (!v) return 'Please enter your name.';
    if (v.length < 2) return 'Name is too short.';
    if (v.length > 40) return 'Name cannot exceed 40 characters.';
    const nameRegex = /^[A-Za-zÀ-ÖØ-öø-ÿ ]+$/;
    if (!nameRegex.test(v)) return 'Name contains invalid characters.';
    return '';
  }

  function validateEmail(email: string): string {
    const v = email.trim();
    if (!v) return 'Please enter your email.';
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(v)) return 'Please enter a valid email.';
    return '';
  }

  function validatePhone(phone: string): string {
    const digits = phone.replace(/\D/g, '');
    if (!digits) return '';
    if (digits.length < 7 || digits.length > 15) {
      return 'Phone must contain 7-15 digits.';
    }
    return '';
  }

  function validateMessage(message: string): string {
    const v = message.trim();
    if (!v) return 'Please write a message.';
    return '';
  }

  function showError(fieldName: string, message: string) {
    const errorEl = document.getElementById(`${fieldName}-error`);
    const inputEl = form.querySelector(`[name="${fieldName}"]`) as HTMLElement;
    if (errorEl && inputEl) {
      errorEl.textContent = message;
      inputEl.classList.add('input-error');
    }
  }

  function clearError(fieldName: string) {
    const errorEl = document.getElementById(`${fieldName}-error`);
    const inputEl = form.querySelector(`[name="${fieldName}"]`) as HTMLElement;
    if (errorEl && inputEl) {
      errorEl.textContent = '';
      inputEl.classList.remove('input-error');
    }
  }

  function clearAllErrors() {
    ['name', 'email', 'phone', 'message'].forEach(clearError);
  }

  function showModal(type: 'success' | 'error', title: string, message: string) {
    const modalIconEl = modal.querySelector('.modal-icon') as HTMLElement;
    modalIconEl.className = `modal-icon ${type}`;
    modalIcon.textContent = type === 'success' ? '✅' : '❌';
    modalTitle.textContent = title;
    modalMessage.textContent = message;
    modal.style.display = 'flex';
  }

  function closeModal() {
    modal.style.display = 'none';
  }

  async function sendEmail(formData: any) {
    try {
      if (!EMAILJS_PUBLIC_KEY || !EMAILJS_SERVICE_ID || !EMAILJS_TEMPLATE_ID) {
        console.error('EmailJS env vars missing');
        return { ok: false, message: 'EmailJS configuration missing.' };
      }

      const templateParams = {
        from_name: formData.name,
        from_email: formData.email,
        phone: formData.phone || 'Not provided',
        company: formData.company || 'Not provided',
        message: formData.message
      };

      const result = await emailjs.send(
        EMAILJS_SERVICE_ID,
        EMAILJS_TEMPLATE_ID,
        templateParams,
        EMAILJS_PUBLIC_KEY
      );

      return { ok: true, message: 'Email sent successfully', result };
    } catch (error: any) {
      console.error('emailjs.send error', error);
      return { ok: false, message: String(error?.text || error?.message || error) };
    }
  }

  async function handleContactForm(formData: any) {
    const name = (formData.name || '').trim();
    const email = (formData.email || '').trim();
    const phoneRaw = (formData.phone || '').trim();
    const message = (formData.message || '').trim();

    const nameError = validateName(name);
    if (nameError) return { success: false, message: nameError };

    const emailError = validateEmail(email);
    if (emailError) return { success: false, message: emailError };

    const phoneDigits = phoneRaw.replace(/\D/g, '');
    if (phoneDigits) {
      const phoneError = validatePhone(phoneDigits);
      if (phoneError) return { success: false, message: phoneError };
    }

    const messageError = validateMessage(message);
    if (messageError) return { success: false, message: messageError };

    const payload = {
      ...formData,
      name,
      email,
      phone: phoneDigits || '',
      message
    };

    const result = await sendEmail(payload);
    if (result.ok) {
      return { success: true, message: 'Message sent successfully. We\'ll respond soon 👍', clearForm: true };
    }
    return { success: false, message: result.message || 'Error sending message' };
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    sendBtn.disabled = true;
    sendBtn.textContent = 'Sending...';
    sendBtn.classList.add('sending');

    try {
      clearAllErrors();

      const formData = {
        name: (form.querySelector('[name="name"]') as HTMLInputElement).value,
        email: (form.querySelector('[name="email"]') as HTMLInputElement).value,
        phone: (form.querySelector('[name="phone"]') as HTMLInputElement).value,
        company: (form.querySelector('[name="company"]') as HTMLInputElement).value,
        message: (form.querySelector('[name="message"]') as HTMLTextAreaElement).value
      };

      const response = await handleContactForm(formData);

      if (response.success) {
        showModal('success', 'Success!', response.message);
        if (response.clearForm) {
          form.reset();
        }
      } else {
        showModal('error', 'Error', response.message);
      }
    } catch (error) {
      console.error('💥 Unexpected error:', error);
      showModal('error', 'Error', 'Unexpected error. Please try again.');
    } finally {
      sendBtn.disabled = false;
      sendBtn.textContent = 'Send Message';
      sendBtn.classList.remove('sending');
    }
  });

  const nameInput = form.querySelector('[name="name"]') as HTMLInputElement;
  nameInput?.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    target.value = sanitizeName(target.value);
    const error = validateName(target.value);
    if (error) showError('name', error);
    else clearError('name');
  });

  const emailInput = form.querySelector('[name="email"]') as HTMLInputElement;
  emailInput?.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    const error = validateEmail(target.value);
    if (error) showError('email', error);
    else clearError('email');
  });

  const phoneInput = form.querySelector('[name="phone"]') as HTMLInputElement;
  phoneInput?.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    target.value = sanitizePhone(target.value);
    const error = validatePhone(target.value);
    if (error) showError('phone', error);
    else clearError('phone');
  });

  const messageInput = form.querySelector('[name="message"]') as HTMLTextAreaElement;
  messageInput?.addEventListener('input', (e) => {
    const target = e.target as HTMLTextAreaElement;
    const error = validateMessage(target.value);
    if (error) showError('message', error);
    else clearError('message');
  });

  closeModalBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });
</script>

<style>
  .contact-root {
    position: relative;
    z-index: 10;
  }

  .banner-contact {
    position: relative;
    width: min(1200px, 90%);
    margin: 2rem auto 4rem auto;
    padding: 3rem 2rem;
    border-radius: 20px;
    background: linear-gradient(-45deg,
      rgba(0, 255, 76, 0.15),
      rgba(57, 255, 20, 0.1),
      rgba(0, 217, 255, 0.1),
      rgba(0, 255, 76, 0.15));
    background-size: 400% 400%;
    animation: gradientShift 8s ease infinite;
    border: 1px solid rgba(57, 255, 20, 0.3);
    box-shadow: 
      0 8px 32px rgba(57, 255, 20, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    text-align: center;
    overflow: hidden;
  }

  .banner-contact::before {
    content: "";
    position: absolute;
    top: -50%;
    left: -20%;
    width: 140%;
    height: 140%;
    background: radial-gradient(circle at 30% 30%, rgba(57, 255, 20, 0.2), transparent 50%);
    opacity: 0.5;
    filter: blur(40px);
    animation: liquidFloat 8s ease-in-out infinite;
    pointer-events: none;
  }

  .banner-contact h1 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    color: #e9fff3;
    text-shadow: 
      0 0 20px rgba(57, 255, 20, 0.5),
      0 0 40px rgba(57, 255, 20, 0.3);
    margin-bottom: 1rem;
    position: relative;
    z-index: 2;
  }

  .banner-contact h2 {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    font-weight: 400;
    color: rgba(233, 255, 243, 0.85);
    margin: 0;
    line-height: 1.5;
    position: relative;
    z-index: 2;
  }

  .contact-container {
    width: min(1100px, 94%);
    margin: 0 auto 4rem auto;
  }

  .contact-content {
    display: grid;
    grid-template-columns: 0.8fr 1.6fr;
    gap: 2rem;
    align-items: start;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-box {
    display: flex;
    gap: 1rem;
    align-items: center;
    border-radius: 16px;
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(57, 255, 20, 0.2);
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 30px rgba(57, 255, 20, 0.1);
    transition: all 0.3s ease;
    cursor: default;
  }

  .info-box:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 40px rgba(57, 255, 20, 0.2);
    border-color: rgba(57, 255, 20, 0.4);
    background: rgba(0, 0, 0, 0.5);
  }

  .info-icon {
    min-width: 52px;
    min-height: 52px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 1.3rem;
    background: rgba(57, 255, 20, 0.1);
    transition: all 0.25s ease;
  }

  .info-box:hover .info-icon {
    background: rgba(57, 255, 20, 0.2);
    transform: scale(1.1);
  }

  .info-box h4 {
    margin: 0 0 0.25rem 0;
    color: #e9fff3;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .info-box p.muted {
    margin: 0;
    color: rgba(233, 255, 243, 0.75);
    font-size: 0.95rem;
  }

  .info-box p.muted.phone-number {
    letter-spacing: 0.1em;
    font-variant-numeric: tabular-nums;
  }

  .contact-form {
    border-radius: 20px;
    padding: 2rem;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(57, 255, 20, 0.2);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(14px);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-form h3 {
    margin: 0 0 1rem 0;
    color: #e9fff3;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .contact-form input,
  .contact-form textarea {
    padding: 0.9rem 1rem;
    border-radius: 10px;
    border: 1px solid rgba(57, 255, 20, 0.2);
    outline: none;
    font-size: 0.95rem;
    background: rgba(0, 0, 0, 0.3);
    color: #e9fff3;
    transition: all 0.25s ease;
    width: 100%;
    box-sizing: border-box;
    font-family: inherit;
  }

  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: rgba(233, 255, 243, 0.5);
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    border-color: rgba(57, 255, 20, 0.5);
    box-shadow: 0 0 20px rgba(57, 255, 20, 0.2);
    background: rgba(0, 0, 0, 0.4);
  }

  .contact-form input.input-error,
  .contact-form textarea.input-error {
    border-color: #ff4757;
    box-shadow: 0 0 15px rgba(255, 71, 87, 0.3);
  }

  .field-error {
    color: #ff6b80;
    font-size: 0.85rem;
    margin: 0.25rem 0 0 0;
    min-height: 1.2em;
  }

  .contact-form textarea {
    grid-column: 1 / -1;
    resize: vertical;
    min-height: 120px;
    margin-top: 0.5rem;
  }

  .form-actions {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .send-btn {
    background: linear-gradient(135deg, #00ff4c, #00d9ff);
    color: #060707;
    border: none;
    border-radius: 10px;
    flex: 1;
    padding: 1rem 1.5rem;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(57, 255, 20, 0.3);
    transition: all 0.3s ease;
  }

  .send-btn:hover:not(:disabled) {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(57, 255, 20, 0.4);
  }

  .send-btn:disabled,
  .send-btn.sending {
    background: linear-gradient(135deg, #6c757d, #495057);
    cursor: not-allowed;
    opacity: 0.7;
  }

  .form-note {
    font-size: 0.9rem;
    color: rgba(233, 255, 243, 0.7);
    margin-top: 0.5rem;
    text-align: center;
  }

  /* Modal styles */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(5px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    animation: fadeIn 0.3s ease;
  }

  .modal-content {
    background: rgba(0, 0, 0, 0.9);
    border: 1px solid rgba(57, 255, 20, 0.3);
    border-radius: 20px;
    padding: 2.5rem;
    max-width: 450px;
    width: 90%;
    text-align: center;
    box-shadow: 0 20px 60px rgba(57, 255, 20, 0.3);
    animation: slideUp 0.3s ease;
  }

  .modal-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 1.5rem;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 2.5rem;
  }

  .modal-icon.success {
    background: rgba(57, 255, 20, 0.2);
    border: 2px solid rgba(57, 255, 20, 0.5);
  }

  .modal-icon.error {
    background: rgba(255, 71, 87, 0.2);
    border: 2px solid rgba(255, 71, 87, 0.5);
  }

  .modal-content h4 {
    color: #e9fff3;
    font-size: 1.8rem;
    margin: 0 0 1rem 0;
  }

  .modal-content p {
    color: rgba(233, 255, 243, 0.85);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0 0 2rem 0;
  }

  .modal-btn {
    background: linear-gradient(135deg, #00ff4c, #00d9ff);
    color: #060707;
    border: none;
    border-radius: 10px;
    padding: 0.9rem 2rem;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .modal-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(57, 255, 20, 0.4);
  }

  /* Animations */
  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  @keyframes liquidFloat {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(15px) scale(1.05); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive */
  @media (max-width: 900px) {
    .contact-content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .contact-info {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .info-box {
      flex: 1;
      min-width: 250px;
    }
  }

  @media (max-width: 600px) {
    .banner-contact {
      padding: 2rem 1.5rem;
      margin: 1.5rem auto 3rem auto;
    }

    .contact-form {
      padding: 1.5rem;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .contact-info {
      flex-direction: column;
    }

    .info-box {
      min-width: 100%;
    }
  }
</style>
